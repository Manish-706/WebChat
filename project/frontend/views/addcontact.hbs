<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Contact | WebChat</title>
    <link rel="stylesheet" href="/styles/auth.css">
</head>

<body>
    <main class="auth-shell">
        <section class="brand-panel">
            <img src="https://robohash.org/webchat-contact.png?set=set4&size=160x160" alt="Cartoon animal avatar">
            <p class="eyebrow">New contact</p>
            <h1>Add someone to your chat list.</h1>
            <p>Save their name and mobile number, then open the conversation from your chat dashboard.</p>
        </section>

        <section class="auth-panel">
            <form action="/addcontact" method="POST" class="registration-form">
                <h1>Add Contact</h1>
                <p class="form-copy">Contacts receive their own cartoon animal avatar automatically.</p>

                <label for="username">Name</label>
                <input type="text" id="username" name="username" autocomplete="name" required>

                <label for="phone">Mobile number</label>
                <input type="tel" id="phone" name="phone" autocomplete="tel" required>

                <button type="submit">Add contact</button>
                <a class="back-link" href="/Mycontacts">Back to chats</a>
            </form>
        </section>
    </main>
</body>

</html>
