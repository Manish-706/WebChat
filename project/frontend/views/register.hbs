<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register | WebChat</title>
    <link rel="stylesheet" href="/styles/auth.css">
</head>

<body>
    <main class="auth-shell">
        <section class="brand-panel">
            <img src="https://robohash.org/webchat-register.png?set=set4&size=160x160" alt="Cartoon animal avatar">
            <p class="eyebrow">WebChat</p>
            <h1>Create your chat identity.</h1>
            <p>Your profile gets a unique cartoon animal avatar after registration.</p>
        </section>

        <section class="auth-panel">
            <form action="/Register" method="POST" class="registration-form">
                <h1>Register</h1>
                <p class="form-copy">Create an account to start adding contacts.</p>

                <label for="username">Username</label>
                <input type="text" id="username" name="username" autocomplete="username" required>

                <label for="phone">Phone</label>
                <input type="tel" id="phone" name="phone" autocomplete="tel" required>

                <label for="email">Email</label>
                <input type="email" id="email" name="email" autocomplete="email" required>

                <label for="gender">Gender</label>
                <select id="gender" name="gender" required>
                    <option value="Male">Male</option>
                    <option value="Female">Female</option>
                    <option value="Other">Other</option>
                </select>

                <label for="age">Age</label>
                <input type="number" id="age" name="age" min="0" required>

                <label for="password">Password</label>
                <input type="password" id="password" name="password" autocomplete="new-password" required>

                <button type="submit">Create account</button>
                <a class="back-link" href="/">Back to welcome</a>
            </form>
        </section>
    </main>
</body>

</html>
