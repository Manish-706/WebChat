<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | WebChat</title>
    <link rel="stylesheet" href="/styles/auth.css">
</head>

<body>
    <main class="auth-shell">
        <section class="brand-panel">
            <img src="https://robohash.org/webchat-login.png?set=set4&size=160x160" alt="Cartoon animal avatar">
            <p class="eyebrow">WebChat</p>
            <h1>Your conversations are waiting.</h1>
            <p>Jump back into your contacts and continue messaging in real time.</p>
        </section>

        <section class="auth-panel">
            <form action="/Login" method="POST" class="registration-form">
                <h1>Login</h1>
                <p class="form-copy">Use your registered mobile number and password.</p>

                <label for="phone">Mobile number</label>
                <input type="tel" id="phone" name="phone" autocomplete="tel" required>

                <label for="password">Password</label>
                <input type="password" id="password" name="password" autocomplete="current-password" required>

                <button type="submit">Login</button>
                <a class="back-link" href="/">Back to welcome</a>
            </form>
        </section>
    </main>
</body>

</html>
